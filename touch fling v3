-- === PROXIMITY FLING (KEINE BERÜHRUNG NÖTIG!) ===
-- Das Herzstück: Scannt alle Spieler in 50 Studs Radius
local function proximityFling()
    while touchFlingActive do
        task.wait(0.03) -- 30ms Loop – extrem schnell
        
        -- Scanne alle Spieler in der Nähe
        for _, targetPlayer in pairs(players:GetPlayers()) do
            if targetPlayer ~= player and targetPlayer.Character then
                local targetChar = targetPlayer.Character
                local targetRoot = targetChar:FindFirstChild("HumanoidRootPart") or targetChar:FindFirstChild("Torso") or targetChar:FindFirstChild("Head")
                
                if targetRoot then
                    local position = character:FindFirstChild("HumanoidRootPart") and character.HumanoidRootPart.Position or character.PrimaryPart.Position
                    local distance = (targetRoot.Position - position).Magnitude
                    
                    -- Nur Spieler in 50 Studs Entfernung flingen
                    if distance < 50 then
                        -- EXTREMER FLING: Zufällige Richtung, maximale Kraft
                        local randomDirection = Vector3.new(
                            math.random(-100000, 100000),
                            math.random(50000, 100000),
                            math.random(-100000, 100000)
                        )
                        
                        targetRoot.Velocity = randomDirection
                        targetRoot.RotVelocity = Vector3.new(
                            math.random(-99999, 99999),
                            math.random(-99999, 99999),
                            math.random(-99999, 99999)
                        )
                        
                        -- Zerstöre alle Gelenke (damit der Körper auseinanderfliegt)
                        for _, joint in pairs(targetChar:GetDescendants()) do
                            if joint:IsA("JointInstance") or joint:IsA("Weld") or joint:IsA("Motor6D") then
                                pcall(function() joint:Destroy() end)
                            end
                        end
                        
                        -- AssemblyLinearVelocity für extra Schub
                        pcall(function()
                            targetRoot.AssemblyLinearVelocity = Vector3.new(0, 100000, 0)
                        end)
                        
                        -- Falls es "Humanoid" gibt: sofort tot setzen
                        if targetChar:FindFirstChild("Humanoid") then
                            targetChar.Humanoid.Health = 0
                            targetChar.Humanoid.BreakJointsOnDeath = false
                        end
                    end
                end
            end
        end
    end
end

-- === GODMODE & NO FALL DAMAGE (wie vorher) ===
local function enableProtection()
    humanoid.MaxHealth = math.huge
    humanoid.Health = math.huge
    humanoid.BreakJointsOnDeath = false
    
    if not humanoid:FindFirstChild("FallDamageConnection") then
        local connection = humanoid.StateChanged:Connect(function(old, new)
            if new == Enum.HumanoidStateType.FallingDown then
                humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                task.wait(0.1)
                humanoid:ChangeState(Enum.HumanoidStateType.Running)
            end
        end)
        local tag = Instance.new("BoolValue")
        tag.Name = "FallDamageConnection"
        tag.Parent = humanoid
    end
end

